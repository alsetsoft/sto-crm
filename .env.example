# ─────────────────────────────────────────────────────────────────────────────
# Environment split: DEV and PROD are fully independent Supabase projects.
# Same schema, different data & auth. Next.js auto-loads files by NODE_ENV.
#
#   npm run dev / tests   → NODE_ENV=development → .env.development(.local)  → DEV db
#   npm run build / start → NODE_ENV=production  → .env.production(.local)   → PROD db
#
# PUBLIC (committed):   .env.development        .env.production
#   NEXT_PUBLIC_SUPABASE_URL          = https://<ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY     = <publishable key, browser-safe>
#
# SECRET (gitignored):  .env.development.local  .env.production.local
#   SUPABASE_SERVICE_ROLE_KEY         = <secret key, server-only — never expose>
#   SUPABASE_DB_URL                   = postgresql://...pooler...  (fill DB password)
#
# SHARED machine-local (gitignored): .env.local
#   BAZA_GAI_TOKEN                    = <baza-gai.com.ua token, same for both envs>
#
# Migrations / Management API (shell env, not a file):
#   SUPABASE_ACCESS_TOKEN             = <personal access token owning both projects>
# ─────────────────────────────────────────────────────────────────────────────

# --- PUBLIC, per environment ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-anon-key>

# --- SECRET, per environment (*.local only) ---
SUPABASE_SERVICE_ROLE_KEY=<secret-service-role-key>
SUPABASE_DB_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Shared integration (.env.local) ---
# Vehicle auto-fill by state registration number (Інтеграції).
# Provider: baza-gai.com.ua — paste the API token here. Without it the
# "Заповнити за держномером" button reports that the service is not configured.
BAZA_GAI_TOKEN=<baza-gai-api-token>
